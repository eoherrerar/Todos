<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>


<BorderPane prefHeight="680.0"
            prefWidth="830.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Main">


    <!-- ENCABEZADO -->

    <top>

        <HBox alignment="CENTER_RIGHT"
              spacing="20">

            <padding>
                <Insets right="20"/>
            </padding>


            <ImageView fitHeight="100"
                       fitWidth="400">

                <image>

                    <Image url="@tra.jpg"/>

                </image>

            </ImageView>


            <Label text="Traductor"
                   style="-fx-font-size:28px;"/>


        </HBox>

    </top>




    <bottom>

        <VBox spacing="15">

            <padding>

                <Insets left="15"
                        right="15"
                        top="10"/>

            </padding>




            <!-- CONSULTA -->


            <TitledPane text="Consulta de traducciones"
                        expanded="true">

                <content>


                    <GridPane hgap="10"
                              vgap="10">


                        <Label text="Palabra"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="0"/>


                        <Label text="Idioma origen"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="0"/>


                        <Label text="Idioma destino"
                               GridPane.columnIndex="2"
                               GridPane.rowIndex="0"/>


                        <Label text="Traducción"
                               GridPane.columnIndex="3"
                               GridPane.rowIndex="0"/>



                        <TextField fx:id="palabra"
                                   prefWidth="130"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="1"/>


                        <ChoiceBox fx:id="idiomaOrigen"
                                   prefWidth="130"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"/>


                        <ChoiceBox fx:id="idiomaDestino"
                                   prefWidth="130"
                                   GridPane.columnIndex="2"
                                   GridPane.rowIndex="1"/>


                        <TextField fx:id="traduccion"
                                   editable="false"
                                   prefWidth="130"
                                   GridPane.columnIndex="3"
                                   GridPane.rowIndex="1"/>



                        <Button text="Traducir"
                                onAction="#traducir"
                                GridPane.columnIndex="4"
                                GridPane.rowIndex="1"/>



                        <Button text="Limpiar"
                                onAction="#limpiarConsulta"
                                GridPane.columnIndex="5"
                                GridPane.rowIndex="1"/>


                    </GridPane>


                </content>


            </TitledPane>






            <!-- AGREGAR -->


            <TitledPane text="Agregar palabras"
                        expanded="true">


                <content>


                    <GridPane hgap="10"
                              vgap="10">


                        <Label text="Palabra en español"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="0"/>


                        <Label text="Palabra traducida"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="0"/>


                        <Label text="Idioma traducción"
                               GridPane.columnIndex="2"
                               GridPane.rowIndex="0"/>



                        <TextField fx:id="palabraEspanol"
                                   prefWidth="150"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="1"/>


                        <TextField fx:id="palabraTraducida"
                                   prefWidth="150"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"/>


                        <ChoiceBox fx:id="idiomaTraduccion"
                                   prefWidth="150"
                                   GridPane.columnIndex="2"
                                   GridPane.rowIndex="1"/>



                        <Button text="Agregar"
                                onAction="#agregar"
                                GridPane.columnIndex="3"
                                GridPane.rowIndex="1"/>


                        <Button text="Limpiar"
                                onAction="#limpiarAgregar"
                                GridPane.columnIndex="4"
                                GridPane.rowIndex="1"/>


                    </GridPane>


                </content>


            </TitledPane>
            <!-- CONTADORES -->


            <TitledPane text="Cantidad de Traducciones"
                        expanded="true">

                <content>

                    <HBox alignment="CENTER"
                          spacing="20">


                        <Label text="Inglés"/>

                        <TextField fx:id="ingles"
                                   editable="false"
                                   prefWidth="50"/>


                        <Label text="Francés"/>

                        <TextField fx:id="frances"
                                   editable="false"
                                   prefWidth="50"/>


                        <Label text="Italiano"/>

                        <TextField fx:id="italiano"
                                   editable="false"
                                   prefWidth="50"/>


                    </HBox>

                </content>

            </TitledPane>





            <!-- ACTUALIZAR PALABRA -->


            <TitledPane text="Actualizar palabra"
                        expanded="true">


                <content>


                    <AnchorPane prefHeight="70">


                        <children>


                            <Label text="Buscar palabra"
                                   layoutX="10"
                                   layoutY="5"/>


                            <TextField fx:id="buscarPalabra"
                                       layoutX="10"
                                       layoutY="25"
                                       prefWidth="120"/>



                            <ChoiceBox fx:id="idiomaBuscar"
                                       layoutX="140"
                                       layoutY="25"
                                       prefWidth="100"/>



                            <Button text="Buscar"
                                    layoutX="250"
                                    layoutY="25"
                                    onAction="#buscar"/>




                            <Label text="Nueva palabra"
                                   layoutX="360"
                                   layoutY="5"/>



                            <TextField fx:id="nuevoEspanol"
                                       layoutX="360"
                                       layoutY="25"
                                       prefWidth="110"/>



                            <Label text="Nuevo significado"
                                   layoutX="490"
                                   layoutY="5"/>



                            <TextField fx:id="nuevoSignificado"
                                       layoutX="490"
                                       layoutY="25"
                                       prefWidth="110"/>



                            <Button text="Actualizar"
                                    layoutX="620"
                                    layoutY="25"
                                    onAction="#actualizar"/>



                            <TextField fx:id="resultadoActualizar"
                                       editable="false"
                                       layoutX="720"
                                       layoutY="25"
                                       prefWidth="80"/>


                        </children>


                    </AnchorPane>


                </content>


            </TitledPane>







            <!-- ELIMINAR PALABRA -->


            <TitledPane text="Eliminar palabra"
                        expanded="true">


                <content>


                    <AnchorPane prefHeight="60">


                        <children>


                            <Label text="Buscar palabra"
                                   layoutX="10"
                                   layoutY="5"/>



                            <TextField fx:id="buscarPalabra1"
                                       layoutX="10"
                                       layoutY="25"
                                       prefWidth="120"/>



                            <ChoiceBox fx:id="idiomaBuscar1"
                                       layoutX="140"
                                       layoutY="25"
                                       prefWidth="100"/>



                            <Button text="Buscar"
                                    layoutX="260"
                                    layoutY="25"
                                    onAction="#buscarEliminar"/>



                            <Button text="Eliminar"
                                    layoutX="380"
                                    layoutY="25"
                                    onAction="#eliminar"/>



                            <TextField fx:id="resultadoEliminar"
                                       editable="false"
                                       layoutX="520"
                                       layoutY="25"
                                       prefWidth="150"/>



                        </children>


                    </AnchorPane>


                </content>


            </TitledPane>




        </VBox>


    </bottom>


</BorderPane>

